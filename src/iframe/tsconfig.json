{
  "compilerOptions": {
    "target":           "ES2020",
    "useDefineForClassFields": true,
    "lib":              ["ES2020", "DOM", "DOM.Iterable"],
    "module":           "ESNext",
    "skipLibCheck":     true,
    "moduleResolution": "bundler",
    "baseUrl":          ".",
    "paths": {
      "@splidejs/react-splide": ["node_modules/@splidejs/react-splide/dist/types/index.d.ts"]
    },
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules":  true,
    "noEmit":           true,
    "jsx":              "react-jsx",
    "strict":           true,
    "noUnusedLocals":   true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src"]
}